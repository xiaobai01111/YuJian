{
  "id": "sms-verification",
  "name": "短信验证服务",
  "version": "1.0.0",
  "description": "支持阿里云、腾讯云短信服务，提供短信验证码发送与验证功能，支持手机号登录",
  "author": "Campus Wall",
  "homepage": "",
  "minAppVersion": "1.0.0",
  
  "permissions": [
    "database:read",
    "database:write",
    "api:register",
    "menu:register",
    "config:read",
    "config:write",
    "http:request",
    "cache:use"
  ],
  
  "menus": [
    {
      "path": "/console/plugins/sms",
      "name": "短信服务",
      "icon": "message-square",
      "parentPath": "/console/system",
      "sortOrder": 200
    }
  ],
  
  "apis": [
    {
      "path": "/api/plugins/sms/send",
      "methods": ["POST"],
      "auth": false,
      "rateLimit": {
        "limit": 1,
        "window": 60
      }
    },
    {
      "path": "/api/plugins/sms/verify",
      "methods": ["POST"],
      "auth": false
    },
    {
      "path": "/api/plugins/sms/config",
      "methods": ["GET", "PUT"],
      "auth": true,
      "permission": "system:sms:config"
    },
    {
      "path": "/api/plugins/sms/test",
      "methods": ["POST"],
      "auth": true,
      "permission": "system:sms:config"
    },
    {
      "path": "/api/plugins/sms/logs",
      "methods": ["GET"],
      "auth": true,
      "permission": "system:sms:config"
    }
  ],
  
  "config": {
    "provider": {
      "type": "select",
      "default": "aliyun",
      "title": "短信服务商",
      "description": "选择短信服务提供商",
      "options": [
        { "value": "aliyun", "label": "阿里云" },
        { "value": "tencent", "label": "腾讯云" }
      ]
    },
    "aliyun.accessKeyId": {
      "type": "string",
      "default": "",
      "title": "阿里云 AccessKey ID",
      "encrypted": true
    },
    "aliyun.accessKeySecret": {
      "type": "string",
      "default": "",
      "title": "阿里云 AccessKey Secret",
      "encrypted": true
    },
    "aliyun.signName": {
      "type": "string",
      "default": "",
      "title": "阿里云短信签名"
    },
    "aliyun.templateCode": {
      "type": "string",
      "default": "",
      "title": "阿里云模板Code"
    },
    "tencent.secretId": {
      "type": "string",
      "default": "",
      "title": "腾讯云 SecretId",
      "encrypted": true
    },
    "tencent.secretKey": {
      "type": "string",
      "default": "",
      "title": "腾讯云 SecretKey",
      "encrypted": true
    },
    "tencent.appId": {
      "type": "string",
      "default": "",
      "title": "腾讯云 AppId"
    },
    "tencent.signName": {
      "type": "string",
      "default": "",
      "title": "腾讯云短信签名"
    },
    "tencent.templateId": {
      "type": "string",
      "default": "",
      "title": "腾讯云模板ID"
    },
    "codeLength": {
      "type": "number",
      "default": 6,
      "title": "验证码长度",
      "min": 4,
      "max": 8
    },
    "codeExpireMinutes": {
      "type": "number",
      "default": 5,
      "title": "验证码有效期(分钟)",
      "min": 1,
      "max": 30
    },
    "dailyLimitPerPhone": {
      "type": "number",
      "default": 10,
      "title": "每日单号码发送上限",
      "min": 1,
      "max": 100
    },
    "ipDailyLimit": {
      "type": "number",
      "default": 50,
      "title": "每日单IP发送上限",
      "min": 10,
      "max": 500
    }
  },

  "entrypoints": {
    "backend": "backend/Plugin.groovy",
    "frontend": "dist/index.js"
  }
}
