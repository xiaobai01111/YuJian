{
  "id": "my-plugin",
  "name": "示例插件",
  "version": "1.0.0",
  "description": "这是一个示例插件",
  "author": "Your Name",
  "homepage": "https://github.com/yourname/my-plugin",
  "minAppVersion": "1.0.0",
  
  "permissions": [
    "database:read",
    "database:write",
    "api:register",
    "menu:register",
    "config:read",
    "config:write"
  ],
  
  "menus": [
    {
      "path": "/console/plugins/my-plugin",
      "name": "示例插件",
      "icon": "puzzle",
      "parentPath": "/console/tools",
      "sortOrder": 100
    }
  ],
  
  "apis": [
    {
      "path": "/api/plugins/my-plugin/**",
      "methods": ["GET", "POST"],
      "auth": true
    }
  ],
  
  "config": {
    "enabled": {
      "type": "boolean",
      "default": true,
      "title": "启用插件",
      "description": "是否启用此插件"
    },
    "apiKey": {
      "type": "string",
      "default": "",
      "title": "API密钥",
      "description": "第三方服务API密钥",
      "encrypted": true
    },
    "maxItems": {
      "type": "number",
      "default": 100,
      "title": "最大条目数",
      "description": "单次处理的最大条目数量",
      "min": 1,
      "max": 1000
    }
  },

  "entrypoints": {
    "backend": "backend/Plugin.groovy",
    "frontend": "dist/index.js"
  }
}
